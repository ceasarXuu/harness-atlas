---
import CardGrid from "../components/CardGrid.astro";
import LearningLayout from "../components/LearningLayout.astro";
import { learningRoadmap } from "../data/site.mjs";
---

<LearningLayout
  active="roadmap"
  title="学习路线 · Harness Atlas"
  description="Harness Atlas 学习路线。"
  kicker="学习 / 学习路线"
  heading="学习路线"
  intro="把 Agent Harness 的学习拆成入门、核心、工程和演进几个阶段。左侧目录在学习区子页面之间切换，并保持同一套学习导航。"
>
  <CardGrid cards={learningRoadmap} />
</LearningLayout>

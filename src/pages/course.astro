---
import BaseLayout from "../layouts/BaseLayout.astro";
import { courseModules, zhNav } from "../data/site.mjs";
---

<BaseLayout
  title="主线课程 · Harness Atlas"
  description="Harness Atlas 主线课程模块。"
  nav={zhNav}
  footerLeft="HARNESS_ATLAS / COURSE"
  footerRight="CC BY 4.0 + MIT"
  styles={["assets/css/learn.css"]}
>
  <section class="section learn-shell">
    <aside class="learn-sidebar" aria-label="学习目录">
      <p class="section-kicker">学习目录</p>
      <nav class="learn-nav" aria-label="学习页目录导航">
        <a href="course.html"><span>路径</span>学习路线</a>
        <a class="active" href="#course-modules"><span>课程</span>主线课程</a>
        <a href="glossary.html"><span>术语</span>术语表</a>
        <a href="patterns.html"><span>实践</span>实践检查清单</a>
      </nav>
      <div class="learn-module-list" aria-label="主线课程模块">
        {courseModules.map(([num, title]) => (
          <a href={`#module-${num}`}>{num} {title}</a>
        ))}
      </div>
    </aside>

    <div id="course-modules" class="learn-content">
      <p class="section-kicker">学习 / 主线课程</p>
      <h1 class="content-title">课程目录</h1>
      <p class="section-intro">系统讲解 Agent Harness 的基础概念、架构组件、协议标准、工程实践与未来演化。左侧目录用于在学习路线、主线课程、术语表和实践检查清单之间切换。</p>
      <div class="course">
        {courseModules.map(([num, title, body]) => (
          <div id={`module-${num}`} class="row"><strong>{num}</strong><div><h3>{title}</h3><p>{body}</p></div></div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

---
import CardGrid from "../components/CardGrid.astro";
import LearningLayout from "../components/LearningLayout.astro";
import { getLearningPager, glossaryPage } from "../data/site.mjs";

const pager = getLearningPager(glossaryPage.active);
---

<LearningLayout
  active={glossaryPage.active}
  locale={glossaryPage.locale}
  title={glossaryPage.title}
  description={glossaryPage.description}
  kicker={glossaryPage.kicker}
  heading={glossaryPage.heading}
  intro={glossaryPage.intro}
  pager={pager}
>
  <CardGrid cards={glossaryPage.cards} compact />
</LearningLayout>

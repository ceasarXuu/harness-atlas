---
import LearningLayout from "../components/LearningLayout.astro";
import { englishGlossaryPage, getLearningPager } from "../data/site.mjs";
import { Content as GlossaryContent } from "../generated/course/en/resources/glossary-bilingual.md";

const pager = getLearningPager(englishGlossaryPage.active, englishGlossaryPage.locale);
---

<LearningLayout
  active={englishGlossaryPage.active}
  locale={englishGlossaryPage.locale}
  title={englishGlossaryPage.title}
  description={englishGlossaryPage.description}
  kicker={englishGlossaryPage.kicker}
  heading={englishGlossaryPage.heading}
  intro={englishGlossaryPage.intro}
  pager={pager}
  localeHref={englishGlossaryPage.localeHref}
>
  <article class="chapter-content">
    <GlossaryContent />
  </article>
</LearningLayout>

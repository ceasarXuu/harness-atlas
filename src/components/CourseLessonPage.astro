---
import CardGrid from "./CardGrid.astro";
import LearningLayout from "./LearningLayout.astro";
import { getLearningPager } from "../data/site.mjs";

const { page } = Astro.props;
const pager = getLearningPager(page.key);
---

<LearningLayout
  active={page.key}
  locale={page.locale}
  title={page.title}
  description={page.description}
  kicker={page.kicker}
  heading={page.heading}
  intro={page.intro}
  pager={pager}
>
  <CardGrid cards={page.cards} compact={page.compact} />
</LearningLayout>

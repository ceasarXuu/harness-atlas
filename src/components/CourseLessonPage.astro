---
import CardGrid from "./CardGrid.astro";
import LearningLayout from "./LearningLayout.astro";

const { page } = Astro.props;
---

<LearningLayout
  active={page.key}
  locale={page.locale}
  title={page.title}
  description={page.description}
  kicker={page.kicker}
  heading={page.heading}
  intro={page.intro}
>
  <CardGrid cards={page.cards} compact={page.compact} />
</LearningLayout>

---
import LearningLayout from "./LearningLayout.astro";
import { getLearningPager } from "../data/site.mjs";

const { page, content } = Astro.props;
const ChapterContent = content;
const pager = getLearningPager(page.key, page.locale);
---

<LearningLayout
  active={page.key}
  locale={page.locale}
  title={page.title}
  description={page.description}
  kicker={page.kicker}
  heading={page.heading}
  intro={page.intro}
  pager={pager}
  localeHref={page.localeHref}
>
  <article class="chapter-content">
    {ChapterContent && <ChapterContent />}
  </article>
</LearningLayout>

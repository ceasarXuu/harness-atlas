---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFrameworkNodes, getFrameworkOther, getNavForPage, frameworkChrome } from "../data/site.mjs";

const {
  active,
  locale = "zh-CN",
  title,
  description,
  kicker,
  heading,
  intro,
  pager = {},
  localeHref,
} = Astro.props;
const chrome = frameworkChrome[locale];
const hasPager = Boolean(pager.previous || pager.next);
const lessons = getFrameworkNodes(locale);
const otherItems = getFrameworkOther(locale);
const nav = getNavForPage(locale, localeHref);
---

<BaseLayout
  title={title}
  description={description}
  lang={locale}
  nav={nav}
  footerLeft={chrome.footerLeft}
  footerRight={chrome.footerRight}
  styles={["assets/css/framework.css"]}
>
  <section class="section framework-shell">
    <aside class="framework-sidebar" aria-label={chrome.sidebarAria}>
      <p class="section-kicker">{chrome.sidebarKicker}</p>
      <nav class="framework-nav" aria-label={chrome.directoryAria}>
        {lessons.map((lesson) => (
          <a class:list={[lesson.key === active && "active"]} href={lesson.href}><span>{lesson.num}</span>{lesson.title}</a>
        ))}
        <p class="framework-nav-group">{chrome.otherGroup}</p>
        {otherItems.map((item) => (
          <a class:list={[item.key === active && "active"]} href={item.href}><span>{item.eyebrow}</span>{item.label}</a>
        ))}
      </nav>
    </aside>

    <div class="framework-content">
      <p class="section-kicker">{kicker}</p>
      <h1 class="content-title">{heading}</h1>
      <p class="section-intro">{intro}</p>
      <slot />
      {hasPager && (
        <nav class="framework-pager bottom" aria-label={chrome.directoryAria}>
          {pager.previous && <a href={pager.previous.href}><span>{chrome.previousLabel}</span><strong>{pager.previous.title}</strong></a>}
          {pager.next && <a href={pager.next.href}><span>{chrome.nextLabel}</span><strong>{pager.next.title}</strong></a>}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

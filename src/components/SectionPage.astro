---
import BaseLayout from "../layouts/BaseLayout.astro";
import CardGrid from "./CardGrid.astro";
import { navByLocale } from "../data/site.mjs";

const { page } = Astro.props;
const locale = page.locale;
---

<BaseLayout title={page.title} description={page.description} lang={locale} nav={navByLocale[locale]} footerLeft={page.footer} footerRight={page.footerRight}>
  <section class="section">
    <p class="section-kicker">{page.kicker}</p>
    <h1 class="content-title">{page.heading}</h1>
    <p class="section-intro">{page.intro}</p>
    <CardGrid cards={page.cards} />
  </section>
</BaseLayout>

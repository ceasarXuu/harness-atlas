---
import BaseLayout from "../layouts/BaseLayout.astro";
import CardGrid from "./CardGrid.astro";
import { navByLocale } from "../data/site.mjs";
import { homePages } from "../data/home.mjs";

const { locale } = Astro.props;
const page = homePages[locale];
---

<BaseLayout
  title={page.title}
  description={page.description}
  lang={page.lang}
  nav={navByLocale[locale]}
  footerLeft={page.footerLeft}
  footerRight={page.footerRight}
>
  <section class="hero home-hero harness-hero">
    <div class="hero-main">
      <span class="badge">{page.hero.badge}</span>

      <h1 class="hero-equation" aria-label={page.hero.titleAria}>
        {page.hero.equation.map((token) => (
          <span class:list={["equation-token", token.role]}>{token.text}</span>
        ))}
      </h1>

      <p class="lead hero-thesis">{page.hero.lead}</p>

      <div class="formula-stack" aria-label={page.hero.formulaAria}>
        {page.hero.formulas.map(([label, expression]) => (
          <div class="formula-line">
            <span>{label}</span>
            <code>{expression}</code>
          </div>
        ))}
      </div>

      <div class="hero-principles">
        {page.hero.principles.map(([label, body]) => (
          <div class="hero-principle">
            <span>{label}</span>
            <p>{body}</p>
          </div>
        ))}
      </div>

      <p class="hero-audience">{page.hero.audience}</p>

      <div class="actions">
        {page.hero.actions.map(([href, label, primary]) => (
          <a class:list={["cta", primary && "primary"]} href={href}>{label}</a>
        ))}
      </div>
    </div>

    <aside class="system-card harness-map" aria-label={page.hero.mapAria}>
      <div class="system-head"><span>{page.hero.mapHead[0]}</span><span>{page.hero.mapHead[1]}</span></div>
      <div class="harness-map-body">
        <div class="map-strip map-goal">{page.hero.mapGoal}</div>

        <div class="runtime-ring">
          {page.hero.ringNodes.map(([label, position]) => (
            <span class={`ring-node ${position}`}>{label}</span>
          ))}
          <div class="model-core">
            <span>{page.hero.coreEyebrow}</span>
            <strong>{page.hero.coreTitle}</strong>
          </div>
        </div>

        <div class="loop-pipeline" aria-label={page.hero.loopAria}>
          {page.hero.loop.map((step) => <span>{step}</span>)}
        </div>

        <div class="map-strip map-result">{page.hero.mapResult}</div>
      </div>
    </aside>
  </section>

  {page.sections.map((section) => (
    <section id={section.id} class={section.className}>
      {section.kicker && <p class="section-kicker">{section.kicker}</p>}
      <h2>{section.heading}</h2>
      {section.intro && <p class="section-intro">{section.intro}</p>}
      {section.updates && (
        <div class="timeline-list">
          {section.updates.map((item) => (
            <a
              class="update-row"
              href={item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noreferrer" : undefined}
            >
              <time datetime={item.dateTime}>{item.date}</time>
              <div class="update-copy">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
              <span class="update-tag">{item.tag}</span>
            </a>
          ))}
        </div>
      )}
      {section.action && <div class="actions section-actions"><a class="cta" href={section.action[0]}>{section.action[1]}</a></div>}
      {section.cards && <CardGrid cards={section.cards} compact={section.compact} />}
    </section>
  ))}
</BaseLayout>

<style>
  .harness-hero {
    min-height: auto;
    grid-template-columns: 1fr;
    align-items: stretch;
    gap: 28px;
    padding: 46px 0 58px;
  }

  .hero-main {
    position: relative;
    max-width: 980px;
  }

  .hero-equation {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: clamp(10px, 1.8vw, 20px);
    max-width: 860px;
    margin: 0;
    font: 900 clamp(44px, 7vw, 88px) / 0.95 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: -0.08em;
    text-transform: uppercase;
  }

  .equation-token {
    display: inline-block;
  }

  .equation-token.model,
  .equation-token.agent {
    text-shadow: 3px 0 #777, -3px 0 #333;
  }

  .equation-token.operator {
    color: #777;
    font-size: 0.7em;
    letter-spacing: -0.02em;
    text-shadow: none;
    transform: translateY(-0.08em);
  }

  .equation-token.harness {
    color: #000;
    background: #fff;
    border: 1px solid #fff;
    padding: 0.04em 0.13em 0.09em;
    box-shadow: 9px 9px 0 rgba(255, 255, 255, 0.10);
    text-shadow: none;
  }

  .hero-thesis {
    max-width: 760px;
    margin-top: 28px;
  }

  .formula-stack {
    display: grid;
    gap: 10px;
    max-width: 780px;
    margin-top: 24px;
  }

  .formula-line {
    display: grid;
    grid-template-columns: 118px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    padding: 12px 14px;
    border: 1px solid #3a3a3a;
    background: rgba(255, 255, 255, 0.04);
  }

  .formula-line span {
    color: #aaa;
    font: 800 12px / 1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: 0.10em;
    text-transform: uppercase;
  }

  .formula-line code {
    color: #fff;
    white-space: normal;
    font: 800 14px / 1.45 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .hero-principles {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    max-width: 780px;
    margin-top: 14px;
  }

  .hero-principle {
    min-height: 92px;
    padding: 12px;
    border: 1px solid #333;
    background: rgba(0, 0, 0, 0.58);
  }

  .hero-principle span {
    color: #fff;
    font: 800 12px / 1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-principle p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.55;
  }

  .hero-audience {
    max-width: 780px;
    margin: 16px 0 0;
    color: var(--muted-2);
    font: 700 12px / 1.6 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
  }

  .harness-map {
    align-self: stretch;
    min-height: 520px;
    display: flex;
    flex-direction: column;
  }

  .harness-map-body {
    display: grid;
    grid-template-rows: auto 1fr auto auto;
    gap: 18px;
    height: 100%;
    padding: 18px;
  }

  .map-strip {
    display: flex;
    justify-content: center;
    padding: 10px 12px;
    border: 1px solid #444;
    background: rgba(255, 255, 255, 0.035);
    color: #e8e8e8;
    font: 800 12px / 1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .runtime-ring {
    position: relative;
    min-height: 360px;
    overflow: hidden;
    border: 1px solid #3a3a3a;
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.12), transparent 34%),
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: auto, 24px 24px, 24px 24px;
  }

  .runtime-ring::before {
    content: "";
    position: absolute;
    inset: 38px;
    border: 1px dashed #5a5a5a;
    border-radius: 999px;
  }

  .runtime-ring::after {
    content: "";
    position: absolute;
    inset: 92px;
    border: 1px solid #444;
    transform: rotate(45deg);
  }

  .model-core {
    position: absolute;
    z-index: 2;
    left: 50%;
    top: 50%;
    width: 148px;
    height: 148px;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    padding: 16px;
    border: 2px solid #fff;
    background: #000;
    text-align: center;
    box-shadow: 0 0 0 8px rgba(255, 255, 255, 0.05);
  }

  .model-core span {
    color: #888;
    font: 700 10px / 1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .model-core strong {
    color: #fff;
    font: 900 24px / 1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: -0.05em;
  }

  .ring-node {
    position: absolute;
    z-index: 3;
    padding: 7px 9px;
    border: 1px solid #555;
    background: #050505;
    color: #eee;
    font: 800 11px / 1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ring-node.north {
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
  }

  .ring-node.north-east {
    top: 78px;
    right: 22px;
  }

  .ring-node.south-east {
    right: 28px;
    bottom: 72px;
  }

  .ring-node.south {
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%);
  }

  .ring-node.south-west {
    bottom: 72px;
    left: 22px;
  }

  .ring-node.north-west {
    top: 78px;
    left: 22px;
  }

  .loop-pipeline {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 20px;
    padding: 12px 0;
    border-top: 1px solid #444;
    border-bottom: 1px solid #444;
  }

  .loop-pipeline span {
    position: relative;
    color: #f5f5f5;
    font: 800 12px / 1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
  }

  .loop-pipeline span:not(:last-child)::after {
    content: "→";
    position: absolute;
    right: -16px;
    color: #777;
  }

  .map-result {
    color: #000;
    background: #fff;
    border-color: #fff;
  }

  .timeline-list {
    display: grid;
    gap: 10px;
    margin-top: 28px;
  }

  .update-row {
    display: grid;
    grid-template-columns: 108px minmax(0, 1fr) 132px;
    gap: 18px;
    align-items: start;
    padding: 18px;
    border: 1px solid #555;
    background: rgba(0, 0, 0, 0.58);
  }

  .update-row:hover {
    color: var(--fg);
    border-color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  .update-row time,
  .update-tag {
    color: var(--muted);
    font: 800 12px / 1.4 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: 0.08em;
  }

  .update-tag {
    justify-self: end;
    padding: 5px 7px;
    border: 1px solid #444;
    text-transform: uppercase;
  }

  .update-copy h3 {
    margin: 0 0 7px;
    font-size: 18px;
    line-height: 1.2;
  }

  .update-copy p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .harness-map {
      min-height: 460px;
    }

    .runtime-ring {
      min-height: 300px;
    }
  }

  @media (max-width: 640px) {
    .harness-hero {
      padding-top: 36px;
    }

    .hero-equation {
      gap: 8px 12px;
      font-size: clamp(38px, 13vw, 56px);
    }

    .equation-token.harness {
      box-shadow: 5px 5px 0 rgba(255, 255, 255, 0.10);
    }

    .formula-line {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    .hero-principles {
      grid-template-columns: 1fr;
    }

    .update-row {
      grid-template-columns: 1fr;
    }

    .update-tag {
      justify-self: start;
    }

    .harness-map {
      display: none;
    }
  }
</style>

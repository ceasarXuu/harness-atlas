---
import BaseLayout from "../layouts/BaseLayout.astro";
import { courseLessons, learningChrome, learningOther, navByLocale } from "../data/site.mjs";

const {
  active,
  locale = "zh-CN",
  title,
  description,
  kicker,
  heading,
  intro,
  pager = {},
} = Astro.props;
const chrome = learningChrome[locale];
const hasPager = Boolean(pager.previous || pager.next);
---

<BaseLayout
  title={title}
  description={description}
  lang={locale}
  nav={navByLocale[locale]}
  footerLeft={chrome.footerLeft}
  footerRight={chrome.footerRight}
  styles={["assets/css/learn.css"]}
>
  <section class="section learn-shell">
    <aside class="learn-sidebar" aria-label={chrome.sidebarAria}>
      <p class="section-kicker">{chrome.sidebarKicker}</p>
      <nav class="learn-nav" aria-label={chrome.directoryAria}>
        {courseLessons.map((lesson) => (
          <a class:list={[lesson.key === active && "active"]} href={lesson.href}><span>{lesson.num}</span>{lesson.title}</a>
        ))}
        <p class="learn-nav-group">{chrome.otherGroup}</p>
        {learningOther.map((item) => (
          <a class:list={[item.key === active && "active"]} href={item.href}><span>{item.eyebrow}</span>{item.label}</a>
        ))}
      </nav>
    </aside>

    <div class="learn-content">
      {hasPager && (
        <nav class="learn-pager top" aria-label={chrome.directoryAria}>
          {pager.previous && <a href={pager.previous.href}><span>{chrome.previousLabel}</span><strong>{pager.previous.title}</strong></a>}
          {pager.next && <a href={pager.next.href}><span>{chrome.nextLabel}</span><strong>{pager.next.title}</strong></a>}
        </nav>
      )}
      <p class="section-kicker">{kicker}</p>
      <h1 class="content-title">{heading}</h1>
      <p class="section-intro">{intro}</p>
      <slot />
      {hasPager && (
        <nav class="learn-pager bottom" aria-label={chrome.directoryAria}>
          {pager.previous && <a href={pager.previous.href}><span>{chrome.previousLabel}</span><strong>{pager.previous.title}</strong></a>}
          {pager.next && <a href={pager.next.href}><span>{chrome.nextLabel}</span><strong>{pager.next.title}</strong></a>}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

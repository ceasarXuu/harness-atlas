---
const {
  nav,
  brandAriaLabel = "Harness Atlas",
  navAriaLabel = "Navigation",
} = Astro.props;
---

<header class="top">
  <a class="brand" href="./" aria-label={brandAriaLabel}>
    <span class="brand-mark" aria-hidden="true"></span>
    <span>HARNESS_ATLAS</span>
  </a>
  <nav class="nav" aria-label={navAriaLabel}>
    {
      nav.map((item) => (
        <a
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noreferrer" : undefined}
        >
          <span>{item.label}</span>
          {item.stat && (
            <span class="nav-stat" aria-label={item.stat.label}>
              ★ {item.stat.value}
            </span>
          )}
        </a>
      ))
    }
  </nav>
</header>
